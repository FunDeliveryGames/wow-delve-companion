<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="DelveCompanionLootInfoHeaderTemplate" virtual="true">
        <Size x="105" y="25" />
        <Layers>
            <Layer level="OVERLAY">
                <Texture atlas="shop-header-menu-BG-divider" useAtlasSize="false">
                    <Size x="2" y="40" />
                    <Anchors>
                        <Anchor point="LEFT" />
                    </Anchors>
                </Texture>
                <Texture parentKey="Icon">
                    <Size x="25" y="25" />
                    <Anchors>
                        <Anchor point="LEFT" x="5" />
                    </Anchors>
                </Texture>
                <FontString parentKey="Text" inherits="GameFontNormalMed2"
                    mixin="AutoScalingFontStringMixin" wordwrap="true" maxLines="2"
                    justifyV="MIDDLE" justifyH="CENTER">
                    <Size x="80" y="25" />
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Icon" relativePoint="RIGHT" />
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>

    <Frame name="DelveCompanionLootInfoColumnHeadersTemplate" virtual="true">
        <Size x="525" y="25" />
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Tier" inherits="GameFontNormalMed2"
                    mixin="AutoScalingFontStringMixin" wordwrap="true" maxLines="2"
                    justifyV="MIDDLE" justifyH="CENTER">
                    <Size x="45" y="25" />
                    <Anchors>
                        <Anchor point="LEFT" x="3" />
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="Container" inherits="HorizontalLayoutFrame">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Tier" relativePoint="RIGHT" />
                </Anchors>
                <KeyValues>
                    <KeyValue key="expand" value="false" type="boolean" />
                    <KeyValue key="spacing" value="10" type="number" />
                </KeyValues>
                <Frames>
                    <Frame parentKey="Bountiful"
                        inherits="DelveCompanionLootInfoHeaderTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="1" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Nemesis"
                        inherits="DelveCompanionLootInfoHeaderTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="2" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Map"
                        inherits="DelveCompanionLootInfoHeaderTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="3" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Vault"
                        inherits="DelveCompanionLootInfoHeaderTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="4" type="number" />
                        </KeyValues>
                    </Frame>
                </Frames>
            </Frame>
        </Frames>
    </Frame>

    <Frame name="DelveCompanionLootInfoElementTemplate" virtual="true">
        <Size x="105" y="25" />
        <Layers>
            <Layer level="OVERLAY">
                <Texture atlas="shop-header-menu-BG-divider" useAtlasSize="false">
                    <Size x="2" y="35" />
                    <Anchors>
                        <Anchor point="LEFT" />
                    </Anchors>
                </Texture>
                <FontString parentKey="Text" inherits="GameFontHighlightMed2"
                    justifyH="CENTER" justifyV="MIDDLE" hidden="true">
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="CrestWidget" inherits="DelveCompanionCustomActionWidgetTemplate"
                hidden="true">
                <Size x="20" y="20" />
                <KeyValues>
                    <KeyValue key="iconSizeX" value="18" type="number" />
                    <KeyValue key="iconSizeY" value="18" type="number" />
                    <KeyValue key="displayLabel" value="false" type="boolean" />
                    <KeyValue key="useAutoScaling" value="false" type="boolean" />
                    <KeyValue key="labelRelPoint" value="LEFT" type="string" />
                    <KeyValue key="labelOffsetX" value="-5" type="number" />
                    <KeyValue key="fontOverride" value="GameFontHighlight" type="string" />
                </KeyValues>
            </Frame>
        </Frames>
    </Frame>

    <Frame name="DelveCompanionLootInfoRowTemplate" virtual="true">
        <Size x="525" y="25" />
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Tier" inherits="GameFontNormalMed2"
                    mixin="AutoScalingFontStringMixin" wordwrap="true" maxLines="2"
                    justifyV="MIDDLE" justifyH="CENTER">
                    <Size x="45" y="20" />
                    <Anchors>
                        <Anchor point="LEFT" x="3" />
                    </Anchors>
                </FontString>
                <Texture atlas="delves-companion-divider"
                    useAtlasSize="false">
                    <Size x="490" y="5" />
                    <Anchors>
                        <Anchor point="TOP" />
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="Container" inherits="HorizontalLayoutFrame">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Tier" relativePoint="RIGHT" />
                </Anchors>
                <KeyValues>
                    <KeyValue key="expand" value="false" type="boolean" />
                    <KeyValue key="spacing" value="10" type="number" />
                </KeyValues>
                <Frames>
                    <Frame parentKey="Bountiful"
                        inherits="DelveCompanionLootInfoElementTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="1" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Nemesis"
                        inherits="DelveCompanionLootInfoElementTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="2" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Map"
                        inherits="DelveCompanionLootInfoElementTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="3" type="number" />
                        </KeyValues>
                    </Frame>
                    <Frame parentKey="Vault"
                        inherits="DelveCompanionLootInfoElementTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="4" type="number" />
                        </KeyValues>
                    </Frame>
                </Frames>
            </Frame>
        </Frames>
    </Frame>

    <Frame name="DelveCompanionLootInfoFrameTemplate" inherits="DefaultPanelTemplate"
        mixin="DelveCompanion_LootInfoFrameMixin" enableMouse="true" hidden="true"
        clampedToScreen="true" frameStrata="HIGH" virtual="true">
        <Size x="450" y="345" />
        <Frames>
            <Button parentKey="CloseButton" inherits="UIPanelCloseButtonDefaultAnchors" />

            <ScrollFrame parentKey="RowsScroll" inherits="ScrollFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" x="7" />
                    <Anchor point="BOTTOMRIGHT" x="-5" />
                </Anchors>
                <ScrollChild>
                    <Frame parentKey="Content">
                        <Size x="525" y="345" />
                        <Frames>
                            <Frame parentKey="ColumnHeaders"
                                inherits="DelveCompanionLootInfoColumnHeadersTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" y="-35" />
                                </Anchors>
                            </Frame>

                            <Frame parentKey="Rows" inherits="VerticalLayoutFrame">
                                <KeyValues>
                                    <KeyValue key="expand" value="false" type="boolean" />
                                </KeyValues>
                                <Anchors>
                                    <Anchor point="TOPLEFT" relativeKey="$parent.ColumnHeaders"
                                        relativePoint="BOTTOMLEFT"
                                        y="-5" />
                                </Anchors>
                            </Frame>
                        </Frames>
                    </Frame>
                </ScrollChild>
            </ScrollFrame>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad" />
            <OnShow method="OnShow" />
        </Scripts>
    </Frame>

    <Button name="DelveCompanionLootInfoButtonTemplate" inherits="MagicButtonTemplate"
        virtual="true" frameLevel="20">
        <Size x="50" y="20" />
        <KeyValues>
            <KeyValue key="fitTextWidthPadding" value="20" />
        </KeyValues>
    </Button>
</Ui>